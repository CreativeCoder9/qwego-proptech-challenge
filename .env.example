# Core application config
# Used by Payload CMS for signing/auth internals.
PAYLOAD_SECRET=replace-with-a-strong-random-secret

# Database connection for Payload's SQLite adapter.
# Default in code is file:./payload.db if omitted.
DATABASE_URL=file:./payload.db
# Optional libSQL/Turso auth token. Required for secured remote libSQL URLs.
LIBSQL_AUTH_TOKEN=

# Seed script config (npm run seed)
# Required by src/seed.ts, must be at least 12 chars.
SEED_PASSWORD=ChangeMe-Seed-2026

# SMTP config for Payload email (used for notification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME=Property Manager

# Optional public app URL used in email ticket links.
# Example: http://localhost:3000 (dev) or https://app.example.com (prod)
APP_BASE_URL=http://localhost:3000

# Optional business profile shown in the Payload admin dashboard welcome panel.
BUSINESS_NAME=SKY Properties
BUSINESS_TAGLINE=Delivering responsive, transparent, and reliable property operations.
BUSINESS_ADDRESS=221B Baker Street, London NW1
BUSINESS_EMAIL=support@sky-properties.com
BUSINESS_PHONE=+1 (800) 555-0114
BUSINESS_HOURS=Mon-Fri, 8:00 AM - 6:00 PM

# Optional management portal URL used by the dashboard redirect button.
# If omitted, defaults to APP_BASE_URL + /dashboard, then /dashboard.
MANAGEMENT_PORTAL_URL=http://localhost:3000/dashboard

# Optional runtime mode. Seed script refuses to run when NODE_ENV=production.
# NODE_ENV=development
