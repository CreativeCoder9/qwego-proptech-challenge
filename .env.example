# Core application config
# Used by Payload CMS for signing/auth internals.
PAYLOAD_SECRET=replace-with-a-strong-random-secret

# Database connection for Payload's SQLite adapter.
# Default in code is file:./payload.db if omitted.
DATABASE_URL=file:./payload.db

# Seed script config (npm run seed)
# Required by src/seed.ts, must be at least 12 chars.
SEED_PASSWORD=ChangeMe-Seed-2026

# SMTP config for Payload email (used for notification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME=Qwego Property Manager

# Optional public app URL used in email ticket links.
# Example: http://localhost:3000 (dev) or https://app.example.com (prod)
APP_BASE_URL=http://localhost:3000

# Optional runtime mode. Seed script refuses to run when NODE_ENV=production.
# NODE_ENV=development
